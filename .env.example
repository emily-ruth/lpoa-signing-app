# Optional: BlackCloak API origin (no trailing slash). When set, v2 calls:
#   POST {origin}/api/lpoa/sign
#   POST {origin}/api/lpoa/revoke
#   GET  {origin}/api/lpoa/status   (for "Refresh status")
# VITE_LPOA_API_BASE_URL=https://api.blackcloak.com

# Optional: HelloSign / Dropbox Sign API App Client ID if sign response omits client_id.
# VITE_HELLOSIGN_CLIENT_ID=your-client-id

# Local dev only: pass skipDomainVerification to embedded open (requires test_mode signature requests).
# VITE_DROPBOX_SIGN_SKIP_DOMAIN_VERIFICATION=true
